# Ignore compiled binaries and runtime-generated files inside releases.
# The config/ subdirectory of each release IS tracked (generated by package.sh).

# Binaries
*/bin/

# Log output
*/log/

# Bundle mount point (populated at runtime, not committed)
*/apphome/

# Do not ignore config/ — those files are tracked.
# Do not ignore the 'latest' symlink — it is tracked.
